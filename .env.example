# ── LLM 模型配置 ─────────────────────────────────────────────
# litellm 格式：provider/model-name
LCR_DEFAULT_LLM=deepseek/deepseek-chat
LCR_AUDIT_LLM=deepseek/deepseek-chat

# ── Embedding 模型 ────────────────────────────────────────────
LCR_EMBED_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# ── LLM API Keys（由 litellm 自动识别） ───────────────────────
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# ── Auto-tagging（可选，不设置则跳过打标步骤） ─────────────────
LCR_MINIMAX_API_KEY=
LCR_MINIMAX_API_BASE=https://api.minimax.io/v1

# ── Zotero 路径（留空则自动检测） ────────────────────────────
ZOTERO_DIR=

# ── Zotero-MCP 集成（可选，留空则禁用） ──────────────────────
LCR_ZOTERO_MCP_DB_PATH=

# ── 检索调参 ──────────────────────────────────────────────────
# Stage1 每次最多扫描多少篇摘要（越大召回越全，越慢）
LCR_STAGE1_PREFILTER_K=100
# Stage1 cosine distance 阈值（越小越严格，0.55 是较宽松的设置）
LCR_STAGE1_DIST_THRESHOLD=0.55
# 目标总 chunk 数（Stage2 自适应分配每篇取多少片段）
LCR_TARGET_FETCH_CHUNKS=60
# 最终传给 LLM 的 chunk 上限（API/前端默认值）
LCR_EVIDENCE_K=50
# Stage2 每篇论文 chunk 数的参考上限（API/前端默认值）
LCR_CHUNKS_PER_PAPER=4
# 证据审计最低分（低于此分数的 chunk 被过滤）
LCR_EVIDENCE_MIN_SCORE=6.0

# ── MinerU 配置（仅 run_mineru.py 需要） ─────────────────────
MINERU_CONDA_BIN=/home/yourname/.conda/envs/lcr/bin
MINERU_API_URL=http://127.0.0.1:8888